{
  "name": "tijarat-pro",
  "version": "1.0.0",
  "description": "TijaratPro - Smart business software for retail & wholesale",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "npx electron-packager . TijaratPro --platform=darwin --arch=universal --out=dist --overwrite --ignore=\"(dist|.git)\"",
    "build:win": "npx electron-packager . TijaratPro --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"(dist|.git)\""
  },
  "author": "Umair",
  "license": "ISC",
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-packager": "^17.1.2"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4"
  }
}
